{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "installCommand": "npm install",
  "env": {
    "NEXT_PUBLIC_API_URL": "@api-url"
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://cyberpath-api.up.railway.app/api/:path*"
    }
  ]
}
